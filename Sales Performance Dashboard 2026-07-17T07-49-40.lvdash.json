{
  "datasets": [
    {
      "name": "top_products",
      "displayName": "Top Products",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  test.gold.product_metrics\n",
        "ORDER BY\n",
        "  total_revenue DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "top_customers",
      "displayName": "Top Customers",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  test.gold.customer_metrics\n",
        "ORDER BY\n",
        "  lifetime_value DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "daily_summary",
      "displayName": "Daily Sales Summary",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  test.gold.daily_sales_summary"
      ]
    },
    {
      "name": "categories",
      "displayName": "Category Performance",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  test.gold.category_metrics\n",
        "ORDER BY\n",
        "  revenue_share_pct DESC"
      ]
    },
    {
      "name": "8b2fe0ab",
      "displayName": "product_metrics",
      "config": {
        "version": "1.1",
        "source": "test.gold.product_metrics",
        "dimensions": [
          {
            "expr": "source.*"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "4b7a6600",
      "displayName": "Top Ten Products Ranked by Highest Revenue",
      "queryLines": [
        "SELECT\r\n",
        "  *\r\n",
        "FROM\r\n",
        "  test.gold.product_metrics\r\n",
        "ORDER BY\r\n",
        "  total_revenue DESC\r\n",
        "LIMIT 10"
      ]
    }
  ],
